---
import type { ImageMetadata } from 'astro';
import Base from '../layouts/Base.astro';

const modules = import.meta.glob<{ default: ImageMetadata }>(
  '../../assets/raw/wallpapers/*.webp',
  { eager: true }
);
const wallpapers = Object.values(modules).map((m) => m.default.src);
---
<Base>
  <script slot="head" is:inline define:vars={{ wallpapers }}>
    const pick = wallpapers[Math.floor(Math.random() * wallpapers.length)];
    document.documentElement.style.setProperty('--hero-bg', `url("${pick}")`);
  </script>

  <section class="hero">
    <div class="hero__inner">
      <p class="eyebrow">Galaxy on Fire community hub</p>
      <h1 class="logo">The Kaamo Club</h1>
      <p class="lede">Docking systems coming online.</p>
      <a class="button" href="#">Enter the station</a>
    </div>
  </section>
</Base>

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-start;
    padding: 9vh var(--space-5) var(--space-8);
    background-image: var(--hero-bg);
    background-size: cover;
    background-position: center;
    background-color: var(--color-void);
    overflow: hidden;
  }
  .hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse at 50% 30%, rgba(5, 10, 20, 0.45), rgba(5, 10, 20, 0.85) 75%),
      linear-gradient(180deg, rgba(5, 10, 20, 0.35), rgba(5, 10, 20, 0.55));
    pointer-events: none;
  }
  .hero__inner {
    position: relative;
    z-index: 1;
    max-width: 56rem;
    text-align: center;
  }
  .eyebrow {
    font-family: var(--font-ui);
    font-size: 0.75rem;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: var(--color-amber);
    margin: 0 0 var(--space-4);
    text-shadow: 0 0 8px rgba(255, 170, 51, 0.5);
  }
  .logo {
    color: #ffffff;
    margin: 0 0 var(--space-5);
    text-shadow:
      0 0 1px rgba(255, 255, 255, 1),
      0 0 4px rgba(255, 255, 255, 0.95),
      0 0 12px var(--color-holo-glow),
      0 0 24px var(--color-holo),
      0 0 48px var(--color-holo),
      0 0 80px var(--color-holo-dim);
  }
  .lede {
    font-size: 1.25rem;
    color: var(--color-ink-dim);
    margin-bottom: var(--space-8);
  }
</style>
