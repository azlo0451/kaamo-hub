---
import Base from '../layouts/Base.astro';
import RandomBackground from '../components/RandomBackground.astro';
---
<Base>
  <RandomBackground slot="head" />

  <section class="hero">
    <div class="hero__inner">
      <p class="eyebrow">Galaxy on Fire community hub</p>
      <h1 class="logo neon">The Kaamo Club</h1>
      <p class="lede">Docking systems coming online.</p>
      <a class="button" href="/bays">Enter the station</a>
    </div>
  </section>
</Base>

<style>
  .hero {
    position: relative;
    min-height: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-start;
    padding: 9vh var(--space-5) var(--space-8);
    background-image: var(--hero-bg);
    background-size: cover;
    background-position: center;
    background-color: var(--color-void);
    overflow: hidden;
  }
  .hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse at 50% 30%, rgba(5, 10, 20, 0.45), rgba(5, 10, 20, 0.85) 75%),
      linear-gradient(180deg, rgba(5, 10, 20, 0.35), rgba(5, 10, 20, 0.55));
    pointer-events: none;
  }
  .hero__inner {
    position: relative;
    z-index: 1;
    max-width: 56rem;
    text-align: center;
  }
  .eyebrow {
    font-family: var(--font-ui);
    font-size: 0.75rem;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: var(--color-amber);
    margin: 0 0 var(--space-4);
    text-shadow: 0 0 8px rgba(255, 170, 51, 0.5);
  }
  .logo {
    margin: 0 0 var(--space-5);
  }
  .lede {
    font-size: 1.25rem;
    color: var(--color-ink-dim);
    margin-bottom: var(--space-8);
  }
</style>
