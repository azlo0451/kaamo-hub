---
import type { ImageMetadata } from 'astro';

const modules = import.meta.glob<{ default: ImageMetadata }>(
  '../../assets/raw/wallpapers/*.webp',
  { eager: true }
);
const wallpapers = Object.values(modules).map((m) => m.default.src);
---
<script is:inline define:vars={{ wallpapers }}>
  const pick = wallpapers[Math.floor(Math.random() * wallpapers.length)];
  document.documentElement.style.setProperty('--hero-bg', `url("${pick}")`);
</script>
